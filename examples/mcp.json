{
  "mcpServers": {
    "fs": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_replace_me"
      }
    }
  },
  "namespace": true,
  "middleware": {
    "log": { "level": "info" },
    "redact": ["token", "password", "api_key", "authorization"],
    "offload": {
      "thresholdBytes": 16384,
      "dir": "./exports",
      "includeResources": false,
      "inferArrayShape": true
    },
    "hooks": "./middleware.js"
  }
}
